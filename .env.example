# ─────────────────────────────────────────────
#  Librex — Self-Hosting Configuration
# ─────────────────────────────────────────────
#
# 1. Copy this file:
#       cp .env.example .env
#
# 2. Fill in the values below
#
# 3. Start Librex:
#       docker compose up -d --build
#
# ─────────────────────────────────────────────

# Database password — make it something secure
POSTGRES_PASSWORD=librex
POSTGRES_USER=librex
POSTGRES_DB=librex

# Secret for signing login sessions — must be at least 32 random characters
# Generate one: openssl rand -hex 32
BETTER_AUTH_SECRET=change-me-run-openssl-rand-hex-32

# The URL users will open in their browser (no trailing slash)
# Local machine:  http://localhost:3000
# Home server:    http://192.168.1.100:3000
# Custom domain:  https://books.example.com
ORIGIN=http://localhost:3000

# ─── Folders ───────────────────────────────────────────────────────────────────
#
# BOOKS_PATH — where your library book files live on the HOST machine.
#   Inside the container this is always /books.
#   When you add a library in Settings, set its folder to /books (or a subfolder).
#
#   Examples:
#     /mnt/nas/Librex/libraries
#     /home/you/books
#     ./books   ← default (created next to this file)
#
BOOKS_PATH=./books

# BOOKDROP_PATH — where you drop files to import on the HOST machine.
#   Inside the container this is always /bookdrop.
#   In Settings → Bookdrop, set the folder to /bookdrop.
#
#   Examples:
#     /mnt/nas/Librex/bookdrop
#     /home/you/bookdrop
#     ./bookdrop   ← default (created next to this file)
#
BOOKDROP_PATH=./bookdrop

# ─── Optional ──────────────────────────────────────────────────────────────────

# Host port Librex listens on (default: 3000)
# PORT=3000

# Port for the internal Go API (default: 6000)
# API_PORT=6000
