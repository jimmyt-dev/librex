# ─────────────────────────────────────────────
#  Librex — Development Environment
# ─────────────────────────────────────────────

# PostgreSQL connection string
# During local development, this usually points to the postgres service
# started by 'docker compose up -d postgres'
DATABASE_URL=postgresql://librex:librex@localhost:5434/librex

# Port for the Go API (default: 5321)
API_PORT=5321

# The URL users will open in their browser during development
ORIGIN="http://localhost:5173"

# Secret for signing login sessions (at least 32 characters)
BETTER_AUTH_SECRET="dev-secret-only-not-for-production-123"

# ─── Docker Dev Helpers ────────────────────────────────────────────────────────
# These are used if you run the database via docker-compose.yml locally

POSTGRES_USER=librex
POSTGRES_PASSWORD=librex
POSTGRES_DB=librex
PORT=3000
